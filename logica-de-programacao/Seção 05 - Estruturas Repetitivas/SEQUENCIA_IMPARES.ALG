Algoritmo "sequencia_impares"

Var

    x, contador : Inteiro

Inicio

   contador <- 1

   escreva("Digite o valor de X: ")
   leia(x)
   
   escreval()
   
   para contador de contador ate x -1 faca
   
       se contador % 2 <> 0 entao
       
          escreval(contador)

       fimse

   fimpara

Fimalgoritmo