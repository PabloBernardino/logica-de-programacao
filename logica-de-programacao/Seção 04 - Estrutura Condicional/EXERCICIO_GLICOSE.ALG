Algoritmo "exercicio_glicose"

Var

glicose : real

Inicio

   escreval("Digite a medida da glicose: ")
   leia(glicose)

   se(glicose <= 100)entao
      escreval("Classificaçăo: normal")
   senao
        se(glicose > 100) e (glicose<= 140)entao
           escreval("Classificaçăo: elevado")
        senao (glicose > 140)
           escreval("Classificaçăo: diabetes")
        fimse
   fimse

Fimalgoritmo