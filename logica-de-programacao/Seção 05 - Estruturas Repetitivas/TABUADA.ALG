Algoritmo "tabuada"



Var

   tabuada, contador, resultadoTabuada : inteiro

Inicio

      escreval("Deseja a tabuada para qual valor? ")
      leia(tabuada)
      
      para contador de 1 ate 10 faca

           resultadoTabuada <- tabuada * contador

           escreval(tabuada, " x", contador, " =",resultadoTabuada)
      fimpara

Fimalgoritmo