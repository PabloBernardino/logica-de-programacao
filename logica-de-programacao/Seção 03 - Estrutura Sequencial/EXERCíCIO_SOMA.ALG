Algoritmo "exercício_soma"

Var

   valor_x : inteiro
   valor_Y : inteiro
   soma : inteiro


Inicio

      escreva("Digite o valor de X: ")
      leia(valor_x)
      escreva("Digite o valor de Y: ")
      leia(valor_Y)
      
      soma <- valor_x + valor_Y
      
      escreva("SOMA = ", soma)

Fimalgoritmo
